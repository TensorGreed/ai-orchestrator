# API
API_PORT=4000
API_HOST=0.0.0.0
WEB_ORIGIN=http://localhost:5173
WORKFLOW_EXECUTION_TIMEOUT_MS=1200000
EXECUTION_HISTORY_RETENTION_DAYS=30
EXECUTION_HISTORY_PRUNE_INTERVAL_MS=3600000
QUEUE_CONCURRENCY=5
SEED_SAMPLE_WORKFLOWS=false
SESSION_COOKIE_NAME=ao_session
SESSION_TTL_HOURS=168
COOKIE_SECURE=false

# Database
# Leave DB_TYPE=sqlite for the default apps/api/data/orchestrator.db store.
# Set DB_TYPE=postgres to use the PostgreSQL settings below.
DB_TYPE=sqlite
DB_POSTGRESDB_HOST=localhost
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=ai_orchestrator
DB_POSTGRESDB_USER=postgres
DB_POSTGRESDB_PASSWORD=
DB_POSTGRESDB_SSL=false
DB_POSTGRESDB_POOL_SIZE=10

# Auth bootstrap and registration controls
AUTH_ALLOW_PUBLIC_REGISTER=false
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=ChangeThisPassword123!

# Secret encryption (32-byte key as base64; generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
SECRET_MASTER_KEY_BASE64=replace-with-32-byte-base64-key

# Optional provider and vector store keys
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_AI_SEARCH_API_KEY=
AZURE_AI_SEARCH_ENDPOINT=
QDRANT_API_KEY=
QDRANT_ENDPOINT=http://localhost:6333
PINECONE_API_KEY=
# Used by RAG Retrieve when vectorStoreId=pgvector-store
DATABASE_URL=

# Default local Ollama URL
OLLAMA_BASE_URL=http://localhost:11434/v1

# Optional Python binary override for Python code node
PYTHON_BIN=

# Optional: path to Chromium/Chrome executable for HTML PDF rendering (pdf_output renderMode=html)
PDF_CHROMIUM_EXECUTABLE_PATH=

# ---------------------------------------------------------------------------
# Phase 5.1 — Enterprise authentication
# ---------------------------------------------------------------------------

# API keys. 0 = never expire (a default; individual keys can still set their own expiry).
API_KEY_DEFAULT_EXPIRY_DAYS=0

# MFA (TOTP). MFA_ENFORCE=true requires admins to enrol before issuing a session.
MFA_ENABLED=false
MFA_ENFORCE=false
MFA_ISSUER=ai-orchestrator

# SAML 2.0 SSO. Requires optional dep: `pnpm add -w @node-saml/node-saml` (install in apps/api).
SAML_ENABLED=false
SAML_ENTRY_POINT=
SAML_ISSUER=
SAML_CALLBACK_URL=
# PEM-encoded IdP signing certificate (single line — replace newlines with \n).
SAML_IDP_CERT=
# SAML response attribute that carries group memberships (for group-to-role mapping).
SAML_GROUPS_ATTRIBUTE=groups

# LDAP / Active Directory. Requires optional dep: `pnpm add -w ldapts` (install in apps/api).
LDAP_ENABLED=false
LDAP_URL=ldap://ldap.example.com:389
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_BASE_DN=
# User search filter; {{email}} is replaced with the login email.
LDAP_USER_FILTER=(mail={{email}})
# Attribute that carries group memberships (e.g. memberOf for Active Directory).
LDAP_GROUPS_ATTRIBUTE=memberOf

# ---------------------------------------------------------------------------
# Phase 5.3 — External secret providers
# ---------------------------------------------------------------------------
# Default cache TTL applied to new external-provider registrations (can be
# overridden per-provider via cacheTtlMs). Rotations in the upstream provider
# take up to this long to become visible in the runtime.
EXTERNAL_SECRETS_CACHE_TTL_MS=300000

# Optional deps to actually reach each provider:
#   AWS Secrets Manager:   pnpm --filter @ai-orchestrator/api add @aws-sdk/client-secrets-manager
#   HashiCorp Vault:       uses native fetch (no extra dep)
#   Google Secret Manager: pnpm --filter @ai-orchestrator/api add @google-cloud/secret-manager
#   Azure Key Vault:       pnpm --filter @ai-orchestrator/api add @azure/keyvault-secrets @azure/identity

# ---------------------------------------------------------------------------
# Phase 5.4 — Audit logging
# ---------------------------------------------------------------------------
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=365
AUDIT_LOG_PRUNE_INTERVAL_MS=3600000
