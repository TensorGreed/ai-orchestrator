{
  "title": "ai-orchestrator",
  "uid": "ai-orchestrator",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "tags": ["ai-orchestrator", "workflow", "llm"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" },
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active workflow executions",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "ao_workflow_executions_active",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "options": { "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "SLO: execution success",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "ao_slo_success_rate",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.9 },
              { "color": "green", "value": 0.99 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "SLO: p95 latency",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "ao_slo_p95_latency_ms",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 15000 },
              { "color": "red", "value": 30000 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Uptime",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "ao_uptime_seconds",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Execution throughput (per minute)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "rate(ao_workflow_executions_total[1m]) * 60",
          "legendFormat": "total",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        },
        {
          "expr": "rate(ao_workflow_executions_success_total[1m]) * 60",
          "legendFormat": "success",
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        },
        {
          "expr": "rate(ao_workflow_executions_failure_total[1m]) * 60",
          "legendFormat": "failure",
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Execution latency (histogram quantiles)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(ao_workflow_execution_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(ao_workflow_execution_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(ao_workflow_execution_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "HTTP request rate (by status class)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum by (status) (rate(ao_http_requests_by_status[1m]))",
          "legendFormat": "{{status}}",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "HTTP latency p95",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(ao_http_request_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Process memory",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "ao_process_heap_used_bytes",
          "legendFormat": "heap used",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        },
        {
          "expr": "ao_process_rss_bytes",
          "legendFormat": "rss",
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "System load (1m)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "ao_system_load_avg_1m",
          "legendFormat": "load1",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" }
        }
      ]
    }
  ]
}
