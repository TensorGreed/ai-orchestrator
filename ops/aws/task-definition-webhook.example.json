{
  "family": "ai-orchestrator-webhook",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ai-orchestrator-task-role",
  "containerDefinitions": [
    {
      "name": "webhook",
      "image": "ACCOUNT_ID.dkr.ecr.REGION.amazonaws.com/ai-orchestrator:latest",
      "essential": true,
      "portMappings": [{ "containerPort": 4000, "protocol": "tcp" }],
      "environment": [
        { "name": "API_HOST", "value": "0.0.0.0" },
        { "name": "API_PORT", "value": "4000" },
        { "name": "DB_TYPE", "value": "postgres" },
        { "name": "DB_POSTGRESDB_SSL", "value": "true" },
        { "name": "COOKIE_SECURE", "value": "true" },
        { "name": "METRICS_ENABLED", "value": "true" },
        { "name": "WORKER_MODE", "value": "webhook" },
        { "name": "HA_ENABLED", "value": "false" }
      ],
      "secrets": [
        {
          "name": "SECRET_MASTER_KEY_BASE64",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:ai-orchestrator/master-key"
        },
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:ai-orchestrator/db-url"
        }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "wget -qO- http://localhost:4000/health || exit 1"],
        "interval": 10,
        "timeout": 3,
        "retries": 5,
        "startPeriod": 30
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/ai-orchestrator",
          "awslogs-region": "REGION",
          "awslogs-stream-prefix": "webhook"
        }
      }
    }
  ]
}
