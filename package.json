{
  "name": "ai-orchestrator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "dev": "concurrently -n api,web,docs -c cyan,magenta,green \"pnpm --filter @ai-orchestrator/api dev\" \"pnpm --filter @ai-orchestrator/web dev\" \"pnpm --filter @ai-orchestrator/docs dev\"",
    "dev:product": "concurrently -n api,web -c cyan,magenta \"pnpm --filter @ai-orchestrator/api dev\" \"pnpm --filter @ai-orchestrator/web dev\"",
    "e2e:prepare": "node scripts/e2e-prepare.mjs",
    "e2e:dev": "pnpm e2e:prepare && pnpm dev:product",
    "e2e": "pnpm --filter @ai-orchestrator/web e2e",
    "docs:dev": "pnpm --filter @ai-orchestrator/docs dev",
    "docs:build": "pnpm --filter @ai-orchestrator/docs build",
    "docs:preview": "pnpm --filter @ai-orchestrator/docs preview",
    "test": "pnpm -r --if-present test",
    "lint": "pnpm -r --if-present lint",
    "build": "pnpm -r --if-present build"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "concurrently": "^9.2.1",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
